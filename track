<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="GymTrack">
<meta name="theme-color" content="#0d0d12">
<title>GymTrack Pro</title>
<link href="https://fonts.googleapis.com/css2?family=SF+Pro+Display:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&family=Barlow:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<!-- 🔥 Firebase SDK v8 -->
<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-auth.js"></script>
<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-firestore.js"></script>
<script>
  firebase.initializeApp({
    apiKey: "AIzaSyDjDmiEDYblppKJylb1dQQpkSQpjFhquJA",
    authDomain: "fittrack-88ca5.firebaseapp.com",
    projectId: "fittrack-88ca5",
    storageBucket: "fittrack-88ca5.firebasestorage.app",
    messagingSenderId: "234228534015",
    appId: "1:234228534015:web:5de881032c632d09a21aca"
  });

  const _auth = firebase.auth();
  const _db = firebase.firestore();

  window._fbAuth = _auth;
  window._fbSignOut = () => _auth.signOut();
  window._fbSignIn = (a, email, pass) => _auth.signInWithEmailAndPassword(email, pass);
  window._fbSignUp = (a, email, pass) => _auth.createUserWithEmailAndPassword(email, pass);
  
  window._fbSetDoc = async (col, id, data) => {
  try {
    await _db.collection(col).doc(id).set(data, { merge: true });
    console.log("✅ Données sauvegardées:", col, id);
  } catch (err) {
    console.error("❌ Erreur sauvegarde:", err);
    throw err;
  }
};

window._fbGetDoc = async (col, id) => {
  try {
    const snap = await _db.collection(col).doc(id).get();
    if (snap.exists) {
      return { exists: true, data: snap.data() };
    } else {
      return { exists: false, data: {} };
    }
  } catch (err) {
    console.error("❌ Erreur Firestore:", err);
    return { exists: false, data: {} };
  }
};

window._loadDBFromFirestore = async (userId) => {
  try {
    const userDoc = await _db.collection('users').doc(userId).get();
    if (userDoc.exists) {
      window._userData = userDoc.data();
      console.log("✅ Données chargées:", window._userData);
    } else {
      console.log("📝 Nouvel utilisateur, création du profil...");
      const newProfile = {
        profile: { name: '', height: 0, goal: '' },
        sessions: [],
        weights: [],
        measurements: [],
        programs: [],
        foods: [],
        goals: { cal: 0, prot: 0, carb: 0, fat: 0 }
      };
      await _db.collection('users').doc(userId).set(newProfile);
      window._userData = newProfile;
    }
  } catch (err) {
    console.error("❌ Erreur chargement:", err);
  }
};
  _auth.onAuthStateChanged((user) => {
    if (user) {
      window._currentUser = user;
      document.getElementById('auth-screen').style.display = 'none';
      document.getElementById('app').style.display = 'flex';
      document.getElementById('auth-user-badge').textContent = '👤 ' + user.email.split('@')[0];
      window._loadDBFromFirestore(user.uid);
    } else {
      window._currentUser = null;
      document.getElementById('auth-screen').style.display = 'flex';
      document.getElementById('app').style.display = 'none';
    }
  });
</script>
<style>
:root {
  --bg:#0d0d12;
  --s1:#13131a;
  --s2:#1a1a24;
  --s3:#21212e;
  --s4:#2a2a3a;
  --acc:#c8f135;
  --acc2:#ff4d6d;
  --acc3:#3d9cff;
  --acc4:#ffb347;
  --txt:#eeeef5;
  --txt2:#8888a0;
  --txt3:#44445a;
  --bdr:#252535;
  --ok:#3dffa0;
  --r:18px;
  --rs:13px;
  --safe-top: env(safe-area-inset-top, 44px);
  --safe-bottom: env(safe-area-inset-bottom, 34px);
  --nav-h: 83px;
  --header-h: 56px;
}

*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;-webkit-touch-callout:none;}
html{scroll-behavior:smooth;height:100%;}
body{
  background:var(--bg);color:var(--txt);
  font-family:'Barlow',sans-serif;
  height:100%;overflow:hidden;
  font-size:16px;
  -webkit-font-smoothing:antialiased;
}

/* ============ APP SHELL ============ */
#app{display:flex;flex-direction:column;height:100%;height:100dvh;}

/* ============ STATUS BAR AREA ============ */
.status-bar{
  height:var(--safe-top);
  background:rgba(13,13,18,0.95);
  backdrop-filter:blur(20px);
  -webkit-backdrop-filter:blur(20px);
  flex-shrink:0;
  z-index:300;
}

/* ============ TOP HEADER ============ */
.top-header{
  height:var(--header-h);
  background:rgba(13,13,18,0.9);
  backdrop-filter:blur(20px);
  -webkit-backdrop-filter:blur(20px);
  border-bottom:1px solid rgba(255,255,255,0.06);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 20px;flex-shrink:0;z-index:200;position:relative;
}
.header-logo{
  font-size:22px;font-weight:800;letter-spacing:-.5px;color:var(--acc);
  font-family:'Barlow',sans-serif;
}
.header-logo span{color:var(--txt3);}
.header-right{display:flex;align-items:center;gap:10px;}
.header-action{
  width:36px;height:36px;border-radius:50%;
  background:var(--s2);border:1px solid var(--bdr);
  display:flex;align-items:center;justify-content:center;
  font-size:17px;cursor:pointer;
  transition:transform .15s;
}
.header-action:active{transform:scale(.92);}
.header-title{
  position:absolute;left:50%;transform:translateX(-50%);
  font-size:17px;font-weight:700;letter-spacing:-.2px;
  opacity:0;transition:opacity .2s;pointer-events:none;
}
.header-title.show{opacity:1;}

/* ============ CONTENT AREA ============ */
.content-area{
  flex:1;overflow-y:auto;overflow-x:hidden;
  -webkit-overflow-scrolling:touch;
  overscroll-behavior-y:contain;
  padding-bottom:calc(var(--nav-h) + 8px);
}
.content-area::-webkit-scrollbar{display:none;}

/* ============ PAGE ============ */
.page{display:none;min-height:100%;}
.page.active{display:block;}
.page-inner{padding:16px 16px 0;}

/* ============ BOTTOM NAV (iOS style) ============ */
.bot-nav{
  position:fixed;bottom:0;left:0;right:0;
  background:rgba(13,13,18,0.9);
  backdrop-filter:blur(30px);
  -webkit-backdrop-filter:blur(30px);
  border-top:1px solid rgba(255,255,255,0.07);
  z-index:300;
  padding-bottom:var(--safe-bottom);
  height:var(--nav-h);
}
.bnav-inner{
  display:flex;justify-content:space-around;align-items:flex-start;
  height:calc(var(--nav-h) - var(--safe-bottom));
  padding-top:8px;
}
.bnav-btn{
  display:flex;flex-direction:column;align-items:center;gap:4px;
  padding:0 10px;cursor:pointer;border:none;background:none;
  color:var(--txt3);font-size:10px;font-weight:600;
  font-family:'Barlow',sans-serif;letter-spacing:.3px;
  flex:1;min-width:44px;max-width:80px;
  transition:all .15s;
  -webkit-user-select:none;
}
.bnav-ico{
  width:46px;height:30px;display:flex;align-items:center;justify-content:center;
  border-radius:10px;font-size:22px;transition:all .2s;
  position:relative;
}
.bnav-btn.active .bnav-ico{background:rgba(200,241,53,.12);}
.bnav-btn.active{color:var(--acc);}
.bnav-btn:active{opacity:.7;transform:scale(.93);}
.bnav-badge{
  position:absolute;top:-4px;right:-2px;
  background:var(--acc2);color:#fff;
  font-size:9px;font-weight:700;
  border-radius:10px;padding:1px 5px;
  border:2px solid var(--bg);
}

/* ============ MORE DRAWER ============ */
.more-drawer{
  position:fixed;bottom:0;left:0;right:0;z-index:400;
  transform:translateY(100%);
  transition:transform .35s cubic-bezier(.32,.72,0,1);
}
.more-drawer.open{transform:translateY(0);}
.drawer-bg{
  position:fixed;inset:0;background:rgba(0,0,0,.6);
  z-index:399;opacity:0;transition:opacity .3s;pointer-events:none;
}
.drawer-bg.open{opacity:1;pointer-events:all;}
.drawer-inner{
  background:var(--s1);
  border-top-left-radius:24px;border-top-right-radius:24px;
  padding:8px 20px 0;
  border:1px solid rgba(255,255,255,.06);
}
.drawer-handle{
  width:36px;height:4px;background:var(--txt3);
  border-radius:2px;margin:0 auto 20px;
}
.drawer-title{font-size:13px;font-weight:600;color:var(--txt2);letter-spacing:.5px;text-transform:uppercase;margin-bottom:16px;}
.drawer-grid{
  display:grid;grid-template-columns:repeat(4,1fr);gap:10px;
  padding-bottom:calc(var(--safe-bottom) + 16px);
}
.drawer-item{
  display:flex;flex-direction:column;align-items:center;gap:7px;
  padding:14px 8px;background:var(--s2);border-radius:16px;
  cursor:pointer;border:1px solid var(--bdr);font-size:12px;
  color:var(--txt2);font-weight:600;
  transition:all .15s;
}
.drawer-item .dico{font-size:24px;}
.drawer-item.active,.drawer-item:active{
  border-color:var(--acc);color:var(--acc);
  background:rgba(200,241,53,.05);
}

/* ============ HERO SECTION ============ */
.hero-section{
  padding:20px 16px 16px;
  background:linear-gradient(160deg,rgba(200,241,53,.04),transparent 50%);
}
.hero-greeting{font-size:28px;font-weight:800;line-height:1.1;letter-spacing:-.5px;}
.hero-greeting .acc{color:var(--acc);}
.hero-date{font-size:14px;color:var(--txt2);margin-top:5px;font-weight:500;}

/* ============ STAT PILLS (dashboard) ============ */
.stat-row{
  display:flex;gap:10px;overflow-x:auto;padding:0 16px 16px;
  scrollbar-width:none;-ms-overflow-style:none;
}
.stat-row::-webkit-scrollbar{display:none;}
.stat-pill{
  flex-shrink:0;background:var(--s1);border:1px solid var(--bdr);
  border-radius:16px;padding:14px 18px;min-width:110px;
  position:relative;overflow:hidden;
}
.stat-pill::before{
  content:'';position:absolute;top:-30px;right:-20px;
  width:70px;height:70px;border-radius:50%;
  background:var(--acc);opacity:.04;
}
.stat-pill .val{font-size:28px;font-weight:800;color:var(--acc);font-family:'JetBrains Mono',monospace;line-height:1;}
.stat-pill .lbl{font-size:11px;color:var(--txt2);margin-top:5px;font-weight:600;letter-spacing:.3px;}
.stat-pill.blue .val{color:var(--acc3);}
.stat-pill.blue::before{background:var(--acc3);}
.stat-pill.red .val{color:var(--acc2);}
.stat-pill.red::before{background:var(--acc2);}
.stat-pill.orange .val{color:var(--acc4);}
.stat-pill.orange::before{background:var(--acc4);}

/* ============ CARDS ============ */
.card{
  background:var(--s1);border:1px solid var(--bdr);
  border-radius:var(--r);padding:18px;margin-bottom:14px;
}
.card-header{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:14px;
}
.card-t{
  font-size:11px;letter-spacing:1.5px;text-transform:uppercase;
  color:var(--acc);font-weight:700;
}
.card-action{
  font-size:12px;color:var(--txt2);font-weight:600;
  cursor:pointer;padding:4px 10px;background:var(--s2);
  border-radius:20px;border:1px solid var(--bdr);
}

/* ============ WEEK ROW ============ */
.week-row{display:grid;grid-template-columns:repeat(7,1fr);gap:5px;}
.week-day{
  display:flex;flex-direction:column;align-items:center;gap:4px;
  padding:8px 3px;border-radius:12px;
  background:var(--s2);border:1px solid var(--bdr);
}
.week-day.today{border-color:var(--acc);background:rgba(200,241,53,.06);}
.week-day .wd-name{font-size:9px;color:var(--txt3);font-weight:700;letter-spacing:.5px;text-transform:uppercase;}
.week-day .wd-ico{font-size:15px;line-height:1;}
.week-day .wd-num{font-size:11px;color:var(--txt3);font-weight:600;}
.week-day.today .wd-name,.week-day.today .wd-num{color:var(--acc);}

/* ============ CAL RING COMPACT ============ */
.cal-ring-row{display:flex;align-items:center;gap:16px;}
.macro-pills{display:flex;flex-direction:column;gap:8px;flex:1;}
.macro-pill-row{display:flex;align-items:center;gap:8px;}
.macro-label{font-size:12px;color:var(--txt2);width:70px;font-weight:600;}
.macro-bar-wrap{flex:1;height:5px;background:var(--s3);border-radius:3px;overflow:hidden;}
.macro-bar-fill{height:100%;border-radius:3px;transition:width .5s;}
.macro-val{font-size:12px;font-family:'JetBrains Mono',monospace;color:var(--txt);width:55px;text-align:right;}

/* ============ PR ROW ============ */
.pr-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:10px 0;border-bottom:1px solid var(--bdr);font-size:14px;
}
.pr-row:last-child{border-bottom:none;}
.pr-name{font-weight:600;flex:1;}
.pr-val{font-family:'JetBrains Mono',monospace;color:var(--acc);font-weight:600;}

/* ============ SECTION TITLE ============ */
.section-title{
  font-size:20px;font-weight:800;letter-spacing:-.3px;
  padding:4px 16px 12px;
}
.section-title .acc{color:var(--acc);}

/* ============ INPUTS iOS ============ */
input,select,textarea{
  background:var(--s2);border:1px solid var(--bdr);border-radius:13px;
  color:var(--txt);font-family:'Barlow',sans-serif;font-size:16px;
  padding:13px 16px;width:100%;
  transition:border-color .2s,box-shadow .2s;outline:none;
  -webkit-appearance:none;appearance:none;
}
input:focus,select:focus,textarea:focus{
  border-color:var(--acc);
  box-shadow:0 0 0 3px rgba(200,241,53,.12);
}
input::placeholder,textarea::placeholder{color:var(--txt3);}
select option{background:var(--s2);}
label{display:block;font-size:13px;color:var(--txt2);margin-bottom:6px;font-weight:600;letter-spacing:.1px;}
.fg{margin-bottom:14px;}
.row{display:flex;gap:10px;align-items:center;}
.f1{flex:1;}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}

/* ============ BUTTONS iOS ============ */
.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:7px;
  padding:14px 20px;border-radius:14px;font-family:'Barlow',sans-serif;
  font-size:16px;font-weight:700;cursor:pointer;border:none;
  transition:all .12s;-webkit-user-select:none;
  letter-spacing:.1px;
}
.btn:active{transform:scale(.96);}
.btn-p{background:var(--acc);color:#0d0d12;}
.btn-p:active{background:#b5dc20;}
.btn-d{background:var(--acc2);color:#fff;}
.btn-g{background:var(--s2);color:var(--txt2);border:1px solid var(--bdr);}
.btn-g:active{border-color:var(--acc);color:var(--acc);}
.btn-sm{padding:9px 14px;font-size:14px;border-radius:11px;}
.btn-full{width:100%;}
.btn-icon{padding:12px;border-radius:13px;width:46px;height:46px;}

/* ============ TAGS ============ */
.tag{display:inline-block;padding:4px 10px;border-radius:20px;font-size:11px;font-weight:700;letter-spacing:.2px;}
.tg{background:rgba(61,255,160,.12);color:var(--ok);}
.tb{background:rgba(61,156,255,.12);color:var(--acc3);}
.ty{background:rgba(200,241,53,.12);color:var(--acc);}
.tr{background:rgba(255,77,109,.12);color:var(--acc2);}
.to{background:rgba(255,179,71,.12);color:var(--acc4);}

/* ============ BADGE ============ */
.badge{display:inline-block;background:rgba(200,241,53,.15);border:1px solid rgba(200,241,53,.3);color:var(--acc);border-radius:20px;padding:3px 10px;font-size:11px;font-weight:700;}

/* ============ PROGRESS ============ */
.pbar{height:8px;background:var(--s3);border-radius:4px;overflow:hidden;margin:4px 0;}
.pfill{height:100%;border-radius:4px;transition:width .5s ease;}

/* ============ TIMER ============ */
.timer-big{
  font-family:'JetBrains Mono',monospace;
  font-size:80px;color:var(--acc);text-align:center;
  line-height:1;letter-spacing:4px;
  font-weight:400;
}
.timer-presets{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;}

/* ============ EXO CARD ============ */
.exo-card{
  background:var(--s2);border:1px solid var(--bdr);border-radius:14px;
  padding:14px;cursor:pointer;transition:all .15s;
  display:flex;flex-direction:column;gap:8px;
}
.exo-card:active{border-color:var(--acc);background:rgba(200,241,53,.04);}
.exo-name{font-weight:700;font-size:14px;line-height:1.3;}
.exo-meta{font-size:11px;color:var(--txt3);}
.exo-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:9px;}

/* ============ SEARCH BAR ============ */
.search-wrap{
  position:relative;padding:0 16px 12px;
}
.search-input{
  padding-left:44px !important;
  border-radius:14px !important;
}
.search-ico{
  position:absolute;left:28px;top:50%;transform:translateY(-50%);
  font-size:17px;color:var(--txt3);pointer-events:none;
}
.search-dropdown{
  position:absolute;left:16px;right:16px;top:100%;margin-top:-8px;
  background:var(--s2);border:1px solid var(--bdr);border-radius:14px;
  z-index:50;max-height:260px;overflow-y:auto;
  box-shadow:0 20px 60px rgba(0,0,0,.5);
}

/* ============ SESSION EXO ITEM ============ */
.sexo-item{
  display:flex;align-items:center;gap:12px;
  padding:14px;background:var(--s2);border-radius:14px;
  margin-bottom:8px;border:1px solid var(--bdr);
}
.sexo-info{flex:1;}
.sexo-name{font-weight:700;font-size:15px;}
.sexo-meta{font-size:12px;color:var(--txt3);margin-top:3px;}

/* ============ FOOD ITEM ============ */
.food-item{
  display:flex;align-items:center;justify-content:space-between;
  padding:13px 16px;background:var(--s2);border-radius:14px;
  margin-bottom:8px;border:1px solid var(--bdr);
}
.food-info{flex:1;}
.food-name{font-weight:600;font-size:15px;}
.food-macros{font-size:12px;color:var(--txt3);margin-top:2px;}

/* ============ TABS ============ */
.tabs{
  display:flex;gap:7px;overflow-x:auto;padding:0 16px 14px;
  scrollbar-width:none;
}
.tabs::-webkit-scrollbar{display:none;}
.tab-btn{
  padding:8px 18px;border-radius:20px;border:1px solid var(--bdr);
  background:var(--s2);color:var(--txt2);font-size:13px;font-weight:700;
  cursor:pointer;transition:all .15s;font-family:'Barlow',sans-serif;
  white-space:nowrap;flex-shrink:0;
}
.tab-btn.active{background:var(--acc);color:#0d0d12;border-color:var(--acc);}
.tab-btn:active{opacity:.8;}

/* ============ CALENDAR ============ */
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:3px;}
.cal-h{text-align:center;font-size:10px;color:var(--txt3);padding:5px 0;text-transform:uppercase;letter-spacing:1px;font-weight:700;}
.cal-d{
  aspect-ratio:1;display:flex;align-items:center;justify-content:center;
  border-radius:10px;font-size:13px;cursor:pointer;transition:all .15s;
  border:1px solid transparent;color:var(--txt3);font-weight:500;
}
.cal-d:active{background:var(--s3);}
.cal-d.today{border-color:var(--acc);color:var(--acc);font-weight:800;}
.cal-d.has-s{background:rgba(200,241,53,.15);color:var(--acc);}
.cal-d.rest{background:rgba(61,156,255,.08);color:var(--acc3);}
.cal-d.empty{opacity:0;cursor:default;}

/* ============ NOTIFICATION ============ */
.notif{
  position:fixed;top:calc(var(--safe-top) + var(--header-h) + 10px);
  left:16px;right:16px;
  background:rgba(30,30,42,.95);
  backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
  border:1px solid rgba(200,241,53,.3);border-radius:16px;
  padding:14px 18px;color:var(--txt);font-size:15px;z-index:9999;
  transform:translateY(-20px);opacity:0;
  transition:transform .3s cubic-bezier(.32,.72,0,1),opacity .3s;
  display:flex;align-items:center;gap:10px;
  font-weight:600;
}
.notif.show{transform:translateY(0);opacity:1;}

/* ============ MODAL ============ */
.modal-bg{
  display:none;position:fixed;inset:0;
  background:rgba(0,0,0,.7);z-index:500;
  align-items:flex-end;justify-content:center;padding:0;
}
.modal-bg.open{display:flex;}
.modal-box{
  background:var(--s1);border:1px solid var(--bdr);
  border-top-left-radius:24px;border-top-right-radius:24px;
  padding:8px 20px 0;width:100%;
  max-height:90dvh;overflow-y:auto;
  animation:slideUp .3s cubic-bezier(.32,.72,0,1);
}
.modal-handle{
  width:36px;height:4px;background:var(--bdr);
  border-radius:2px;margin:0 auto 20px;
}
.modal-inner{padding-bottom:calc(var(--safe-bottom) + 16px);}
@keyframes slideUp{from{transform:translateY(30%);opacity:0}to{transform:translateY(0);opacity:1}}

/* ============ MISC ============ */
.mono{font-family:'JetBrains Mono',monospace;}
.hl{color:var(--acc);}
.hl2{color:var(--acc3);}
.hl3{color:var(--acc4);}
.txt2{color:var(--txt2);}
.txt3{color:var(--txt3);}
.mt8{margin-top:8px;}
.mt16{margin-top:16px;}
.mb16{margin-bottom:16px;}
::-webkit-scrollbar{display:none;}

/* ============ SESSION FAB ============ */
.session-fab{
  display:none;position:fixed;
  bottom:calc(var(--nav-h) + 10px);right:16px;
  background:var(--acc);color:#0d0d12;border:none;
  border-radius:50px;padding:13px 20px;font-weight:800;font-size:14px;
  cursor:pointer;z-index:150;
  box-shadow:0 4px 24px rgba(200,241,53,.35);
  align-items:center;gap:8px;font-family:'Barlow',sans-serif;
  transition:transform .15s;
}
.session-fab:active{transform:scale(.95);}
.session-fab.visible{display:flex;}

/* ============ LIST ITEMS ============ */
.list-item{
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 16px;background:var(--s2);border-radius:14px;
  margin-bottom:8px;border:1px solid var(--bdr);
}

/* ============ EMPTY STATE ============ */
.empty-state{
  text-align:center;padding:40px 20px;
  color:var(--txt3);font-size:15px;
}
.empty-state .empty-ico{font-size:48px;margin-bottom:12px;}
.empty-state p{font-weight:500;}

/* ============ PULL TO REFRESH ============ */
.pull-indicator{
  text-align:center;padding:12px;font-size:13px;
  color:var(--txt3);font-weight:600;
}

/* ============ SWIPE CARD ============ */
.swipe-wrap{position:relative;overflow:hidden;border-radius:14px;margin-bottom:8px;}
.swipe-actions{
  position:absolute;right:0;top:0;bottom:0;
  display:flex;align-items:stretch;
}
.swipe-del{
  background:var(--acc2);color:#fff;
  display:flex;align-items:center;justify-content:center;
  width:70px;font-size:20px;cursor:pointer;border:none;
  font-family:'Barlow',sans-serif;font-weight:700;
}

/* ============ HISTORY CARD ============ */
.hist-card{
  background:var(--s1);border:1px solid var(--bdr);
  border-radius:16px;margin-bottom:12px;overflow:hidden;
}
.hist-header{
  padding:14px 16px;
  border-bottom:1px solid var(--bdr);
  display:flex;align-items:center;justify-content:space-between;
}
.hist-name{font-weight:800;font-size:16px;}
.hist-meta{font-size:12px;color:var(--txt2);margin-top:3px;font-weight:500;}
.hist-exos{padding:8px 16px 14px;}
.hist-exo-row{
  display:flex;align-items:center;gap:10px;
  padding:7px 0;border-bottom:1px solid var(--bdr);
  font-size:14px;
}
.hist-exo-row:last-child{border-bottom:none;}

/* ============ TABLE ============ */
table{width:100%;border-collapse:collapse;font-size:14px;}
th{text-align:left;padding:8px 10px;color:var(--txt3);font-size:11px;letter-spacing:1px;border-bottom:1px solid var(--bdr);font-weight:700;}
td{padding:10px;border-bottom:1px solid rgba(37,37,53,.5);}

/* ============ SETTINGS ROWS ============ */
.settings-group{background:var(--s1);border:1px solid var(--bdr);border-radius:16px;overflow:hidden;margin-bottom:16px;}
.settings-row{
  display:flex;align-items:center;justify-content:space-between;
  padding:15px 16px;border-bottom:1px solid var(--bdr);font-size:15px;font-weight:500;
}
.settings-row:last-child{border-bottom:none;}
.settings-row-ico{font-size:22px;margin-right:12px;}

/* ============ HAPTIC FEEDBACK ============ */
@media (prefers-reduced-motion: no-preference) {
  .btn:active,.bnav-btn:active,.exo-card:active,.card:active{
    animation:haptic .1s ease;
  }
}
@keyframes haptic{0%{transform:scale(1)}50%{transform:scale(.97)}100%{transform:scale(1)}}


/* ============ AUTH SCREEN ============ */
#auth-screen{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  position:fixed;inset:0;background:var(--bg);z-index:9999;
  padding:32px 24px;overflow-y:auto;
}
#app{display:none;}
.auth-logo{font-size:36px;font-weight:800;letter-spacing:-1px;color:var(--acc);margin-bottom:6px;font-family:'Barlow',sans-serif;}
.auth-logo span{color:var(--txt3);}
.auth-sub{font-size:14px;color:var(--txt2);margin-bottom:36px;font-weight:500;}
.auth-card{background:var(--s1);border:1px solid var(--bdr);border-radius:20px;padding:24px;width:100%;max-width:400px;}
.auth-tabs{display:flex;gap:0;margin-bottom:24px;background:var(--s2);border-radius:12px;padding:3px;}
.auth-tab{flex:1;padding:9px;text-align:center;border-radius:10px;font-weight:700;font-size:14px;cursor:pointer;color:var(--txt2);transition:all .2s;border:none;background:none;font-family:'Barlow',sans-serif;}
.auth-tab.active{background:var(--acc);color:#0d0d12;}
.auth-error{background:rgba(255,77,109,.1);border:1px solid rgba(255,77,109,.3);color:var(--acc2);border-radius:12px;padding:11px 14px;font-size:13px;font-weight:600;margin-bottom:12px;display:none;}
.auth-error.show{display:block;}
.auth-loading{background:rgba(200,241,53,.08);border:1px solid rgba(200,241,53,.2);color:var(--acc);border-radius:12px;padding:11px 14px;font-size:13px;font-weight:600;margin-bottom:12px;display:none;text-align:center;}
.auth-loading.show{display:block;}
.auth-footer{margin-top:24px;text-align:center;font-size:12px;color:var(--txt3);}
.config-notice{background:rgba(255,179,71,.08);border:1px solid rgba(255,179,71,.3);color:var(--acc4);border-radius:14px;padding:14px;font-size:13px;font-weight:600;margin-bottom:20px;max-width:400px;width:100%;text-align:center;line-height:1.5;}
#auth-user-badge{font-size:11px;color:var(--txt2);font-weight:600;background:var(--s2);border:1px solid var(--bdr);border-radius:20px;padding:5px 10px;cursor:pointer;max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
</style>
</head>
<body>

<!-- ===== AUTH SCREEN ===== -->
<div id="auth-screen">
  <div id="config-notice-wrap" class="config-notice" style="display:none">
    ⚠️ <strong>Configuration requise</strong><br>
    Remplace les valeurs <code>REMPLACE_PAR_...</code> dans le code<br>par ta config Firebase pour activer les comptes.
  </div>
  <div class="auth-logo">GYM<span>TRACK</span></div>
  <div class="auth-sub">Ton coach fitness personnel 💪</div>
  <div class="auth-card">
    <div class="auth-tabs">
      <button class="auth-tab active" id="tab-login" onclick="switchAuthTab('login')">Connexion</button>
      <button class="auth-tab" id="tab-signup" onclick="switchAuthTab('signup')">Créer un compte</button>
    </div>
    <div class="auth-loading" id="auth-loading">⏳ Connexion en cours...</div>
    <div class="auth-error" id="auth-error"></div>
    <div class="fg"><label>Email</label><input type="email" id="auth-email" placeholder="toi@exemple.com" autocomplete="email"></div>
    <div class="fg" id="auth-name-wrap" style="display:none"><label>Prénom</label><input type="text" id="auth-name" placeholder="Ton prénom"></div>
    <div class="fg"><label>Mot de passe</label><input type="password" id="auth-password" placeholder="••••••••" autocomplete="current-password"></div>
    <button class="btn btn-p btn-full mt16" id="auth-submit-btn" onclick="submitAuth()">Se connecter</button>
    <div class="auth-footer">Tes données sont sauvegardées dans le cloud 🔒</div>
  </div>
</div>


<div class="notif" id="notif">✅ Action effectuée</div>

<button class="session-fab" id="session-fab" onclick="showPage('session')">🏋️ Séance en cours</button>

<div id="app">
  <!-- STATUS BAR -->
  <div class="status-bar"></div>

  <!-- TOP HEADER -->
  <div class="top-header" id="top-header">
    <div class="header-logo">GYM<span>TRACK</span></div>
    <div class="header-title" id="header-title">Dashboard</div>
    <div class="header-right">
      <div class="header-action" onclick="showPage('session')">🏋️</div>
      <div id="auth-user-badge" onclick="confirmLogout()" title="Cliquer pour se déconnecter">👤</div>
      <span id="auth-user-email" style="display:none"></span>
    </div>
  </div>

  <!-- CONTENT -->
  <div class="content-area" id="content-area">

    <!-- ===== DASHBOARD ===== -->
    <div class="page active" id="page-dashboard">
      <div class="hero-section">
        <div class="hero-greeting">Bon retour,<br><span class="acc" id="username-display">Athlète</span> 💪</div>
        <div class="hero-date" id="dashboard-date"></div>
      </div>

      <!-- Stats pills -->
      <div class="stat-row">
        <div class="stat-pill">
          <div class="val" id="stat-sessions">0</div>
          <div class="lbl">Séances / mois</div>
        </div>
        <div class="stat-pill blue">
          <div class="val" id="stat-weight">--</div>
          <div class="lbl">Poids (kg)</div>
        </div>
        <div class="stat-pill orange">
          <div class="val" id="stat-streak">0</div>
          <div class="lbl">Jours streak</div>
        </div>
        <div class="stat-pill red">
          <div class="val" id="stat-pr">0</div>
          <div class="lbl">PRs ce mois</div>
        </div>
      </div>

      <div class="page-inner">
        <!-- Quick action -->
        <button class="btn btn-p btn-full mb16" onclick="showPage('session')" style="font-size:17px;padding:17px">▶ Lancer une séance</button>

        <!-- Semaine -->
        <div class="card">
          <div class="card-header">
            <div class="card-t">📅 Cette semaine</div>
          </div>
          <div class="week-row" id="week-overview"></div>
        </div>

        <!-- Calories du jour -->
        <div class="card" id="dash-cal-card">
          <div class="card-header">
            <div class="card-t">🔥 Calories aujourd'hui</div>
            <div class="card-action" onclick="showPage('nutrition')">Voir tout →</div>
          </div>
          <div class="cal-ring-row">
            <svg width="88" height="88" viewBox="0 0 88 88" style="flex-shrink:0">
              <circle cx="44" cy="44" r="38" fill="none" stroke="var(--s3)" stroke-width="10"/>
              <circle id="cal-ring" cx="44" cy="44" r="38" fill="none" stroke="var(--acc)" stroke-width="10"
                stroke-dasharray="238.8" stroke-dashoffset="238.8" stroke-linecap="round"
                transform="rotate(-90 44 44)" style="transition:stroke-dashoffset .6s"/>
              <text x="44" y="48" text-anchor="middle" fill="var(--acc)" font-size="16" font-weight="700" font-family="JetBrains Mono,monospace" id="cal-ring-txt">0</text>
            </svg>
            <div class="macro-pills">
              <div class="macro-pill-row">
                <span class="macro-label" style="color:var(--acc3)">Protéines</span>
                <div class="macro-bar-wrap"><div class="macro-bar-fill" id="bar-prot-d" style="background:var(--acc3);width:0%"></div></div>
                <span class="macro-val" id="dash-prot">0g</span>
              </div>
              <div class="macro-pill-row">
                <span class="macro-label" style="color:var(--acc4)">Glucides</span>
                <div class="macro-bar-wrap"><div class="macro-bar-fill" id="bar-carb-d" style="background:var(--acc4);width:0%"></div></div>
                <span class="macro-val" id="dash-carb">0g</span>
              </div>
              <div class="macro-pill-row">
                <span class="macro-label" style="color:var(--acc2)">Lipides</span>
                <div class="macro-bar-wrap"><div class="macro-bar-fill" id="bar-fat-d" style="background:var(--acc2);width:0%"></div></div>
                <span class="macro-val" id="dash-fat">0g</span>
              </div>
              <div style="font-size:12px;color:var(--txt3)" id="dash-cal-summary">Configure tes objectifs →</div>
            </div>
          </div>
        </div>

        <!-- PRs -->
        <div class="card">
          <div class="card-header">
            <div class="card-t">🏆 Derniers PRs</div>
            <div class="card-action" onclick="showPage('progressive')">Voir tout →</div>
          </div>
          <div id="pr-list"><div class="empty-state" style="padding:16px 0"><p>Aucun PR encore</p></div></div>
        </div>

        <!-- Poids chart -->
        <div class="card">
          <div class="card-header"><div class="card-t">📊 Évolution poids</div></div>
          <canvas id="weight-chart-dash" height="120" role="img" aria-label="Courbe poids"></canvas>
        </div>
      </div>
    </div>

    <!-- ===== SÉANCE ===== -->
    <div class="page" id="page-session">
      <div class="hero-section" style="padding-bottom:4px">
        <div style="display:flex;align-items:center;justify-content:space-between">
          <div>
            <div class="hero-greeting" style="font-size:24px">🏋️ <span class="acc">Séance</span></div>
            <div id="session-timer" class="mono" style="font-size:20px;color:var(--acc3);margin-top:4px">00:00:00</div>
          </div>
          <button class="btn btn-p" onclick="saveSession()" style="font-size:15px;padding:12px 18px">💾 Terminer</button>
        </div>
      </div>

      <div class="page-inner">
        <!-- Session info -->
        <div class="card">
          <div class="fg"><label>Nom de la séance</label><input type="text" id="session-name" placeholder="Push Day, Legs, Full Body…"></div>
          <div class="fg" style="margin:0"><label>Groupe musculaire</label>
            <select id="session-muscle">
              <option value="">-- Choisir --</option>
              <option>Pectoraux</option><option>Dos</option><option>Épaules</option>
              <option>Biceps</option><option>Triceps</option><option>Jambes</option>
              <option>Abdominaux</option><option>Full Body</option><option>Cardio</option>
            </select>
          </div>
        </div>

        <!-- Ajouter exercice -->
        <div class="card">
          <div class="card-t" style="margin-bottom:14px">➕ Ajouter un exercice</div>
          <div class="fg" style="position:relative">
            <label>Exercice</label>
            <div style="position:relative">
              <span style="position:absolute;left:14px;top:50%;transform:translateY(-50%);font-size:17px;color:var(--txt3);z-index:1">🔍</span>
              <input type="text" id="exo-search" placeholder="Rechercher un exercice…" oninput="searchExos()" autocomplete="off" style="padding-left:44px">
            </div>
            <div id="exo-dropdown" style="display:none;position:absolute;left:0;right:0;top:calc(100% + 4px);background:var(--s2);border:1px solid var(--bdr);border-radius:14px;z-index:50;max-height:220px;overflow-y:auto;box-shadow:0 20px 50px rgba(0,0,0,.5);"></div>
            <input type="hidden" id="exo-select-val">
            <input type="hidden" id="exo-muscle-val">
          </div>
          <div id="exo-selected-badge" style="display:none;margin-bottom:12px;"></div>
          <div class="g2" style="margin-bottom:12px">
            <div class="fg" style="margin:0"><label>Séries</label><input type="number" id="exo-sets" value="3" min="1" max="20" inputmode="numeric"></div>
            <div class="fg" style="margin:0"><label>Reps</label><input type="number" id="exo-reps" value="10" min="1" max="100" inputmode="numeric"></div>
            <div class="fg" style="margin:0"><label>Poids (kg)</label><input type="number" id="exo-weight" value="0" step="0.5" min="0" inputmode="decimal"></div>
            <div class="fg" style="margin:0"><label>Repos (s)</label><input type="number" id="exo-rest" value="90" step="15" min="0" inputmode="numeric"></div>
          </div>
          <div class="fg"><label>Notes</label><input type="text" id="exo-notes" placeholder="Sensation, tempo…"></div>
          <button class="btn btn-p btn-full" onclick="addExercise()">➕ Ajouter à la séance</button>
        </div>

        <!-- Exercices en cours -->
        <div class="card">
          <div class="card-t" style="margin-bottom:14px">📋 Exercices de la séance</div>
          <div id="session-exercises">
            <div class="empty-state">
              <div class="empty-ico">🏋️</div>
              <p>Aucun exercice ajouté</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ===== NUTRITION ===== -->
    <div class="page" id="page-nutrition">
