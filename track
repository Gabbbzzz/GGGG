                <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px"><span style="color:var(--acc3);font-weight:600">Protéines</span><span id="nut-prot-txt" class="mono" style="font-size:12px">0 / —g</span></div>
                <div class="pbar"><div class="pfill" id="bar-prot" style="width:0;background:var(--acc3)"></div></div>
              </div>
              <div style="margin-bottom:8px">
                <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px"><span style="color:var(--acc4);font-weight:600">Glucides</span><span id="nut-carb-txt" class="mono" style="font-size:12px">0 / —g</span></div>
                <div class="pbar"><div class="pfill" id="bar-carb" style="width:0;background:var(--acc4)"></div></div>
