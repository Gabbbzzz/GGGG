const NAV_PAGES=['dashboard','session','nutrition','library'];
function showPage(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.bnav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  const bnav=document.getElementById('bnav-'+id);
  if(bnav)bnav.classList.add('active');

  // header title
  const titles={dashboard:'Dashboard',session:'Séance',nutrition:'Repas',library:'Exercices',history:'Historique',weight:'Poids & IMC',measurements:'Mensurations',progressive:'Progression',planner:'Planning',timer:'Timer repos',settings:'Paramètres',cmc:'Dépenses'};
  document.getElementById('header-title').textContent=titles[id]||id;

  // scroll to top
  document.getElementById('content-area').scrollTo({top:0,behavior:'instant'});

  if(id==='dashboard')renderDashboard();
  if(id==='history'){document.getElementById('history-filter').value=new Date().toISOString().slice(0,7);renderHistory();}
  if(id==='library')renderLibrary('Tous');
  if(id==='planner'){renderCalendar();renderWeekGrid();}
  if(id==='progressive'){populateProgExoSelects();renderPRTable();}
  if(id==='weight')renderWeightPage();
  if(id==='measurements')renderMeasPage();
  if(id==='settings')loadSettings();
  if(id==='nutrition'){document.getElementById('food-date-filter').value=today();renderFoodLog();loadGoals();}
  if(id==='cmc')loadCMCFromProfile();
}

function toggleMore(){
  document.getElementById('more-drawer').classList.toggle('open');
  document.getElementById('drawer-bg').classList.toggle('open');
}
function closeMore(){
  document.getElementById('more-drawer').classList.remove('open');
  document.getElementById('drawer-bg').classList.remove('open');
}
