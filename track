            <div class="empty-state" style="padding:16px 0"><div class="empty-ico">🥗</div><p>Aucun aliment enregistré</p></div>
          </div>
        </div>

        <!-- Objectifs -->
        <div class="card">
          <div class="card-t" style="margin-bottom:14px">🎯 Objectifs journaliers</div>
