}

function notify(msg='Enregistré !'){
  const n=document.getElementById('notif');
  n.innerHTML=msg;n.classList.add('show');
  // iOS haptic feedback via vibration
  if(navigator.vibrate)navigator.vibrate(10);
  setTimeout(()=>n.classList.remove('show'),2800);
}

function today(){return new Date().toISOString().split('T')[0];}

// ==================== SESSION ====================
let sessionExercises=[];let sessionStart=null;let sessionTimerInterval=null;
let selectedExo=null;

function searchExos(){
  const q=document.getElementById('exo-search').value.toLowerCase().trim();
  const dd=document.getElementById('exo-dropdown');
  if(!q){dd.style.display='none';return;}
  const results=EXERCISES.filter(e=>e.name.toLowerCase().includes(q)||e.muscle.toLowerCase().includes(q)).slice(0,8);
  if(!results.length){dd.style.display='none';return;}
  dd.style.display='block';
  dd.innerHTML=results.map(e=>`
    <div onclick="selectExo('${e.name.replace(/'/g,"\\'")}','${e.muscle}')"
      style="padding:13px 16px;cursor:pointer;border-bottom:1px solid var(--bdr);display:flex;align-items:center;gap:12px;font-size:14px;"
    >
      <span style="font-size:18px">${e.icon||''}</span>
      <div><div style="font-weight:700">${e.name}</div><div style="font-size:11px;color:var(--txt3);margin-top:2px">${e.muscle} · ${e.type}${e.machine?' · 🔧 Machine':''}</div></div>
    </div>`).join('');
}

function selectExo(name,muscle){
  selectedExo={name,muscle};
  document.getElementById('exo-search').value=name;
  document.getElementById('exo-select-val').value=name;
  document.getElementById('exo-muscle-val').value=muscle;
  document.getElementById('exo-dropdown').style.display='none';
  const c=MUSCLE_COLORS[muscle]||'var(--acc)';
  document.getElementById('exo-selected-badge').style.display='block';
  document.getElementById('exo-selected-badge').innerHTML=`<div style="display:inline-flex;align-items:center;gap:8px;background:rgba(200,241,53,.1);border:1px solid rgba(200,241,53,.3);border-radius:20px;padding:8px 16px;font-size:14px">
    <span style="width:10px;height:10px;border-radius:50%;background:${c};flex-shrink:0;display:inline-block"></span>
    <strong>${name}</strong> <span style="color:var(--txt3)">${muscle}</span>
  </div>`;
}

function addExercise(){
  const name=document.getElementById('exo-select-val').value;
  if(!name){notify('⚠️ Choisis un exercice !');return;}
  sessionExercises.push({
    name,muscle:document.getElementById('exo-muscle-val').value,
    sets:+document.getElementById('exo-sets').value||3,
    reps:+document.getElementById('exo-reps').value||10,
    weight:+document.getElementById('exo-weight').value||0,
    rest:+document.getElementById('exo-rest').value||90,
    notes:document.getElementById('exo-notes').value,
  });
  renderSessionExercises();
  document.getElementById('exo-search').value='';
  document.getElementById('exo-select-val').value='';
  document.getElementById('exo-selected-badge').style.display='none';
  document.getElementById('exo-notes').value='';
  selectedExo=null;
  if(!sessionTimerInterval){sessionStart=sessionStart||Date.now();startSessionTimer();}
  updateFAB();
  notify('✅ Exercice ajouté !');
}

function startSessionTimer(){
  sessionTimerInterval=setInterval(()=>{
    const e=Date.now()-sessionStart;
    const h=Math.floor(e/3600000).toString().padStart(2,'0');
    const m=Math.floor((e%3600000)/60000).toString().padStart(2,'0');
    const s=Math.floor((e%60000)/1000).toString().padStart(2,'0');
    document.getElementById('session-timer').textContent=`${h}:${m}:${s}`;
  },1000);
}

function updateFAB(){
  const fab=document.getElementById('session-fab');
  if(sessionExercises.length>0&&!document.getElementById('page-session').classList.contains('active')){
    fab.classList.add('visible');
  }else{fab.classList.remove('visible');}
}

function renderSessionExercises(){
  const el=document.getElementById('session-exercises');
  if(!sessionExercises.length){
    el.innerHTML='<div class="empty-state" style="padding:16px 0"><div class="empty-ico">💪</div><p>Aucun exercice ajouté</p></div>';
    return;
  }
  el.innerHTML=sessionExercises.map((e,i)=>{
    const c=MUSCLE_COLORS[e.muscle]||'var(--acc)';
    return`<div class="sexo-item">
      <div style="width:4px;height:48px;border-radius:2px;background:${c};flex-shrink:0"></div>
      <div class="sexo-info">
        <div class="sexo-name">${e.name}${e.isPR?' <span class="badge">🏆 PR</span>':''}</div>
        <div class="sexo-meta">${e.sets}×${e.reps} · <span class="mono hl">${e.weight}kg</span> · repos ${e.rest}s</div>
        ${e.notes?`<div style="font-size:12px;color:var(--txt3);margin-top:3px">📝 ${e.notes}</div>`:''}
      </div>
      <button class="btn btn-g btn-sm" onclick="setTimer(${e.rest});showPage('timer')" style="font-size:16px;padding:10px">⏱️</button>
      <button class="btn btn-d btn-sm" onclick="removeExo(${i})" style="font-size:16px;padding:10px">✕</button>
    </div>`;
  }).join('');
}

function removeExo(i){sessionExercises.splice(i,1);renderSessionExercises();}

function saveSession(){
  const name=document.getElementById('session-name').value.trim()||'Séance sans nom';
  if(!sessionExercises.length){notify('⚠️ Ajoute au moins un exercice !');return;}
  const s={
    id:Date.now(),date:today(),
    name,muscle:document.getElementById('session-muscle').value,
    exercises:[...sessionExercises],
    duration:sessionStart?Math.floor((Date.now()-sessionStart)/60000):0,
  };
  DB.sessions.push(s);checkPRs(s);saveDB();
  sessionExercises=[];sessionStart=null;
  clearInterval(sessionTimerInterval);sessionTimerInterval=null;
  document.getElementById('session-timer').textContent='00:00:00';
  document.getElementById('session-name').value='';
  renderSessionExercises();updateFAB();
  notify('💪 Séance sauvegardée !');
  showPage('dashboard');
}

function checkPRs(session){
  session.exercises.forEach(e=>{
    if(!e.weight)return;
    const prev=DB.sessions.flatMap(s=>s.exercises).filter(x=>x.name===e.name&&x.weight>0&&x!==e);
    const mx=Math.max(...prev.map(x=>x.weight),0);
    if(e.weight>mx)e.isPR=true;
  });
}

// ==================== HISTORY ====================
function renderHistory(){
  const filter=document.getElementById('history-filter').value;
  let sessions=[...DB.sessions].sort((a,b)=>new Date(b.date)-new Date(a.date));
  if(filter)sessions=sessions.filter(s=>s.date.startsWith(filter));
  const el=document.getElementById('history-list');
  if(!sessions.length){
    el.innerHTML='<div class="empty-state"><div class="empty-ico">📋</div><p>Aucune séance ce mois</p></div>';
    return;
  }
  el.innerHTML=sessions.map(s=>`
    <div class="hist-card">
      <div class="hist-header">
        <div>
          <div class="hist-name">${s.name}</div>
          <div class="hist-meta">${s.date} · ${s.muscle||''} · ${s.duration||'?'} min · ${s.exercises.length} exercices</div>
        </div>
        <button class="btn btn-d btn-sm" onclick="deleteSession(${s.id})" style="font-size:16px;padding:9px">🗑️</button>
      </div>
      <div class="hist-exos">
        ${s.exercises.map(e=>`
          <div class="hist-exo-row">
            <span style="width:8px;height:8px;border-radius:50%;background:${MUSCLE_COLORS[e.muscle]||'var(--acc)'};flex-shrink:0"></span>
            <span style="flex:1;font-weight:600">${e.name}${e.isPR?' <span class="badge">🏆 PR</span>':''}</span>
            <span class="mono hl" style="font-size:13px">${e.weight}kg</span>
            <span class="txt3" style="font-size:13px;margin-left:8px">${e.sets}×${e.reps}</span>
          </div>`).join('')}
      </div>
    </div>`).join('');
  renderSessionsChart(sessions);
}

function deleteSession(id){
  if(!confirm('Supprimer cette séance ?'))return;
  DB.sessions=DB.sessions.filter(s=>s.id!==id);
  saveDB();renderHistory();
}

function renderSessionsChart(sessions){
  const ctx=document.getElementById('sessions-chart')?.getContext('2d');
  if(!ctx)return;
  const counts={};
  sessions.forEach(s=>{counts[s.date]=(counts[s.date]||0)+1;});
  const labels=Object.keys(counts).sort().slice(-20);
  if(window._sessChart)window._sessChart.destroy();
  window._sessChart=new Chart(ctx,{
    type:'bar',
    data:{labels,datasets:[{label:'Séances',data:labels.map(l=>counts[l]),backgroundColor:'rgba(200,241,53,.45)',borderColor:'var(--acc)',borderRadius:7}]},
    options:{plugins:{legend:{display:false}},scales:{x:{ticks:{color:'#8888a0',font:{size:10}},grid:{color:'#252535'}},y:{ticks:{color:'#8888a0',stepSize:1},grid:{color:'#252535'}}}}
  });
}

