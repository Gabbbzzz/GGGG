function renderPRTable(){
  const allExos=[...new Set(DB.sessions.flatMap(s=>s.exercises.map(e=>e.name)))];
  const prs=allExos.map(name=>{
    const recs=DB.sessions.flatMap(s=>s.exercises.filter(e=>e.name===name).map(e=>({weight:e.weight,date:s.date})));
    if(!recs.length)return null;
    const best=recs.reduce((a,b)=>b.weight>a.weight?b:a);
    return{name,weight:best.weight,date:best.date};
  }).filter(Boolean).sort((a,b)=>b.weight-a.weight);
  const el=document.getElementById('pr-table');
  if(!el)return;
  if(!prs.length){el.innerHTML='<div class="empty-state" style="padding:16px 0"><p>Aucun PR enregistré</p></div>';return;}
  el.innerHTML=`<table><thead><tr><th>Exercice</th><th>Record</th><th>Date</th></tr></thead>
    <tbody>${prs.map(p=>`<tr>
      <td style="font-weight:600">${p.name}</td>
      <td class="mono hl">${p.weight}kg</td>
      <td class="txt3">${p.date}</td>
    </tr>`).join('')}</tbody></table>`;
}

