function renderDashboard(){
  const now=new Date();
  document.getElementById('dashboard-date').textContent=now.toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
  document.getElementById('username-display').textContent=DB.profile.name||'Athlète';
  const thisMonth=now.toISOString().slice(0,7);
  const monthSess=DB.sessions.filter(s=>s.date.startsWith(thisMonth));
  document.getElementById('stat-sessions').textContent=monthSess.length;
  if(DB.weights.length)document.getElementById('stat-weight').textContent=DB.weights[DB.weights.length-1].weight;
  const prs=monthSess.flatMap(s=>s.exercises.filter(e=>e.isPR));
  document.getElementById('stat-pr').textContent=prs.length;
  let streak=0,check=new Date(now);
  for(let i=0;i<365;i++){
    const d=check.toISOString().split('T')[0];
    if(DB.sessions.some(s=>s.date===d)){streak++;check.setDate(check.getDate()-1);}else break;
  }
  document.getElementById('stat-streak').textContent=streak;

  // Week
  const mon=new Date(now);mon.setDate(now.getDate()-((now.getDay()+6)%7));
  const dayNames=['L','M','M','J','V','S','D'];
  let wk='';
  for(let i=0;i<7;i++){
    const d=new Date(mon);d.setDate(mon.getDate()+i);
    const ds=d.toISOString().split('T')[0];
    const hasSess=DB.sessions.some(s=>s.date===ds);
    const prog=DB.programs.find(p=>p.date===ds);
    const isToday=d.toDateString()===now.toDateString();
    wk+=`<div class="week-day ${isToday?'today':''}">
      <span class="wd-name">${dayNames[i]}</span>
      <span class="wd-ico">${hasSess?'✅':prog&&prog.type!=='Repos'?'📋':prog&&prog.type==='Repos'?'😴':'·'}</span>
      <span class="wd-num">${d.getDate()}</span>
    </div>`;
  }
  document.getElementById('week-overview').innerHTML=wk;

  // PRs
  const allPRs=DB.sessions.flatMap(s=>s.exercises.filter(e=>e.isPR).map(e=>({...e,date:s.date})));
  allPRs.sort((a,b)=>new Date(b.date)-new Date(a.date));
  document.getElementById('pr-list').innerHTML=allPRs.slice(0,5).map(e=>`
    <div class="pr-row"><span class="pr-name">${e.name}</span><span class="pr-val">${e.weight}kg 🏆</span></div>`).join('')||'<div class="empty-state" style="padding:16px 0"><p>Aucun PR encore</p></div>';

  renderWeightChart('weight-chart-dash');

  // Dashboard calories
  const todayStr=today();
  const foods=DB.foods.filter(f=>f.date===todayStr);
  const totCal=foods.reduce((s,f)=>s+f.cal,0);
  const totProt=foods.reduce((s,f)=>s+f.prot,0);
  const totCarb=foods.reduce((s,f)=>s+f.carb,0);
  const totFat=foods.reduce((s,f)=>s+f.fat,0);

  const ring=document.getElementById('cal-ring');
  const ringTxt=document.getElementById('cal-ring-txt');
  if(ring&&ringTxt){
    const pct=DB.goals.cal?Math.min(1,totCal/DB.goals.cal):0;
    ring.style.strokeDashoffset=238.8*(1-pct);
    ringTxt.textContent=totCal;
  }
  document.getElementById('dash-prot').textContent=Math.round(totProt)+'g';
  document.getElementById('dash-carb').textContent=Math.round(totCarb)+'g';
  document.getElementById('dash-fat').textContent=Math.round(totFat)+'g';

  // Macro bars
  const setBars=(id,val,goal)=>{const el=document.getElementById(id);if(el)el.style.width=(goal?Math.min(100,val/goal*100):0)+'%';};
  setBars('bar-prot-d',totProt,DB.goals.prot);
  setBars('bar-carb-d',totCarb,DB.goals.carb);
  setBars('bar-fat-d',totFat,DB.goals.fat);

  if(DB.goals.cal){
    document.getElementById('dash-cal-summary').innerHTML=`<strong class="hl">${totCal}</strong> / ${DB.goals.cal} kcal${totCal>=DB.goals.cal?' ✅':` · ${DB.goals.cal-totCal} restantes`}`;
  }
}

// ==================== SWIPE TO DELETE (touch) ====================
function addSwipeToDelete(el,onDelete){
  let startX=0,isDragging=false;
  el.addEventListener('touchstart',e=>{startX=e.touches[0].clientX;isDragging=true;},{passive:true});
  el.addEventListener('touchmove',e=>{
    if(!isDragging)return;
    const dx=e.touches[0].clientX-startX;
    if(dx<-20&&dx>-120)el.style.transform=`translateX(${dx}px)`;
  },{passive:true});
  el.addEventListener('touchend',e=>{
    const dx=e.changedTouches[0].clientX-startX;
    if(dx<-80){el.style.transition='transform .2s';el.style.transform='translateX(-100%)';setTimeout(onDelete,200);}
    else{el.style.transition='transform .2s';el.style.transform='translateX(0)';}
    isDragging=false;
  });
}

