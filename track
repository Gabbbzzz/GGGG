function renderFoodLog(){
  const dateFilter=document.getElementById('food-date-filter').value||today();
  const foods=DB.foods.filter(f=>f.date===dateFilter);
  const totCal=foods.reduce((s,f)=>s+f.cal,0);
  const totProt=foods.reduce((s,f)=>s+f.prot,0);
  const totCarb=foods.reduce((s,f)=>s+f.carb,0);
  const totFat=foods.reduce((s,f)=>s+f.fat,0);

  // ring
  const pct=DB.goals.cal?Math.min(1,totCal/DB.goals.cal):0;
  const ring=document.getElementById('nut-cal-ring');
  const ringTxt=document.getElementById('nut-cal-txt');
  if(ring){ring.style.strokeDashoffset=263.9*(1-pct);ringTxt.textContent=totCal;}
  document.getElementById('nut-cal-goal-txt').textContent=DB.goals.cal?`/ ${DB.goals.cal} kcal`:'/ — kcal';

  const macros=[
    {id:'prot',val:totProt,goal:DB.goals.prot,txt:'nut-prot-txt',bar:'bar-prot'},
    {id:'carb',val:totCarb,goal:DB.goals.carb,txt:'nut-carb-txt',bar:'bar-carb'},
    {id:'fat',val:totFat,goal:DB.goals.fat,txt:'nut-fat-txt',bar:'bar-fat'},
  ];
  macros.forEach(m=>{
    const el=document.getElementById(m.txt);if(el)el.textContent=`${Math.round(m.val)} / ${m.goal||'—'}g`;
    const bar=document.getElementById(m.bar);if(bar)bar.style.width=(m.goal?Math.min(100,m.val/m.goal*100):0)+'%';
  });

  const el=document.getElementById('food-log-list');
  if(!foods.length){
    el.innerHTML='<div class="empty-state" style="padding:16px 0"><div class="empty-ico">🥗</div><p>Aucun aliment enregistré</p></div>';
    return;
  }
  el.innerHTML=foods.map(f=>`
    <div class="food-item">
      <div class="food-info">
        <div class="food-name">${f.name}</div>
        <div class="food-macros">${f.cal} kcal · P:${Math.round(f.prot)}g · G:${Math.round(f.carb)}g · L:${Math.round(f.fat)}g</div>
      </div>
      <button onclick="deleteFood(${f.id})" style="background:none;border:none;font-size:18px;color:var(--acc2);cursor:pointer;padding:8px">✕</button>
    </div>`).join('');
}

// ==================== CMC ====================
function loadCMCFromProfile(){
  document.getElementById('cmc-height').value=DB.profile.height||'';
}
function autoCalcCMC(){if(document.getElementById('cmc-weight').value)calcCMC();}
function calcCMC(){
  const sex=document.getElementById('cmc-sex').value;
  const age=+document.getElementById('cmc-age').value;
  const height=+document.getElementById('cmc-height').value;
  const weight=+document.getElementById('cmc-weight').value;
  const activity=+document.getElementById('cmc-activity').value;
  if(!age||!height||!weight){notify('⚠️ Remplis tous les champs');return;}
  const bmr=sex==='H'?(10*weight)+(6.25*height)-(5*age)+5:(10*weight)+(6.25*height)-(5*age)-161;
  const tdee=Math.round(bmr*activity);
  const goals={Sèche:tdee-500,'Perte de poids':tdee-300,Maintien:tdee,'Prise de masse':tdee+300,'Force':tdee+200};
  const g=DB.profile.goal||'Maintien';
  document.getElementById('cmc-result').innerHTML=`
    <div class="card">
      <div class="card-t" style="margin-bottom:14px">🔥 Résultats</div>
      <div class="stat-row" style="padding:0 0 14px;overflow:visible;flex-wrap:wrap">
        <div class="stat-pill" style="min-width:0;flex:1"><div class="val">${Math.round(bmr)}</div><div class="lbl">MB (kcal)</div></div>
        <div class="stat-pill blue" style="min-width:0;flex:1"><div class="val">${tdee}</div><div class="lbl">TDEE (kcal)</div></div>
        <div class="stat-pill orange" style="min-width:0;flex:1"><div class="val">${goals[g]||tdee}</div><div class="lbl">${g}</div></div>
      </div>
      <div style="margin-top:8px">
        ${Object.entries(goals).map(([k,v])=>`
          <div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--bdr);font-size:14px">
            <span style="font-weight:600">${k}</span>
            <span class="mono hl">${v} kcal</span>
          </div>`).join('')}
      </div>
      <button class="btn btn-p btn-full mt16" onclick="applyCMCGoals(${goals[g]||tdee},${Math.round(weight*2.2)},${Math.round(tdee*.4/4)},${Math.round(tdee*.25/9)})">
        ✅ Appliquer comme objectifs
      </button>
    </div>`;
}
function applyCMCGoals(cal,prot,carb,fat){
  DB.goals={cal,prot,carb,fat};saveDB();
  showPage('nutrition');loadGoals();notify('✅ Objectifs appliqués !');
}

