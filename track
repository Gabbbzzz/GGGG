function updateProgressiveCalc(){
  const name=document.getElementById('prog-exo-select').value;
  const currentW=+document.getElementById('prog-current-weight').value;
  const currentR=+document.getElementById('prog-current-reps').value||8;
  const type=document.getElementById('prog-type-select').value;
  const el=document.getElementById('prog-result');
  if(!currentW){el.innerHTML='';return;}
  let msg='';
  if(type==='double'){
    const maxReps=12;
    if(currentR<maxReps){msg=`Prochaine séance : <span class="hl">${currentW}kg × ${currentR+1} reps</span>`;}
    else{msg=`Monte à <span class="hl">${(currentW+2.5).toFixed(1)}kg × 8 reps</span>`;}
  }else if(type==='linear'){
    msg=`Prochaine séance : <span class="hl">${(currentW+2.5).toFixed(1)}kg × ${currentR} reps</span>`;
  }else{
