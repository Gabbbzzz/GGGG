        <div class="hero-greeting" style="font-size:24px">🍽️ <span class="acc">Repas & Calories</span></div>
      </div>

      <div class="page-inner">
        <!-- Résumé -->
        <div class="card">
          <div class="card-header">
            <div class="card-t">📊 Aujourd'hui</div>
            <input type="date" id="food-date-filter" onchange="renderFoodLog()" style="width:auto;padding:6px 12px;font-size:12px;border-radius:10px">
          </div>
          <div style="display:flex;align-items:center;gap:20px">
            <svg width="100" height="100" viewBox="0 0 100 100" style="flex-shrink:0">
              <circle cx="50" cy="50" r="42" fill="none" stroke="var(--s3)" stroke-width="11"/>
              <circle id="nut-cal-ring" cx="50" cy="50" r="42" fill="none" stroke="var(--acc)" stroke-width="11"
                stroke-dasharray="263.9" stroke-dashoffset="263.9" stroke-linecap="round"
                transform="rotate(-90 50 50)" style="transition:stroke-dashoffset .5s"/>
              <text x="50" y="46" text-anchor="middle" fill="var(--acc)" font-size="18" font-weight="700" font-family="JetBrains Mono,monospace" id="nut-cal-txt">0</text>
