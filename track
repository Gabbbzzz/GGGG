<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="GymTrack">
<meta name="theme-color" content="#0d0d12">
<title>GymTrack Pro</title>
<link href="https://fonts.googleapis.com/css2?family=SF+Pro+Display:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&family=Barlow:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<!-- 🔥 Firebase SDK v8 -->
<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-auth.js"></script>
<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-firestore.js"></script>
<script>
  firebase.initializeApp({
    apiKey: "AIzaSyDjDmiEDYblppKJylb1dQQpkSQpjFhquJA",
    authDomain: "fittrack-88ca5.firebaseapp.com",
    projectId: "fittrack-88ca5",
    storageBucket: "fittrack-88ca5.firebasestorage.app",
    messagingSenderId: "234228534015",
    appId: "1:234228534015:web:5de881032c632d09a21aca"
  });

  const _auth = firebase.auth();
  const _db = firebase.firestore();

  window._fbAuth = _auth;
  window._fbSignOut = () => _auth.signOut();
  window._fbSignIn = (a, email, pass) => _auth.signInWithEmailAndPassword(email, pass);
  window._fbSignUp = (a, email, pass) => _auth.createUserWithEmailAndPassword(email, pass);
  
  window._fbSetDoc = async (col, id, data) => {
    try {
      await _db.collection(col).doc(id).set(data, { merge: true });
      console.log("✅ Données sauvegardées:", col, id);
    } catch (err) {
      console.error("❌ Erreur sauvegarde:", err);
      throw err;
    }
  };

  window._fbGetDoc = async (col, id) => {
    try {
      const snap = await _db.collection(col).doc(id).get();
      if (snap.exists) {
        return { exists: true, data: snap.data() };
      } else {
        return { exists: false, data: {} };
      }
    } catch (err) {
      console.error("❌ Erreur Firestore:", err);
      return { exists: false, data: {} };
    }
  };

  window._loadDBFromFirestore = async (userId) => {
    try {
      const userDoc = await _db.collection('users').doc(userId).get();
      if (userDoc.exists) {
        window._userData = userDoc.data();
        console.log("✅ Données chargées:", window._userData);
      } else {
        console.log("📝 Nouvel utilisateur, création du profil...");
        const newProfile = {
          profile: { name: '', height: 0, goal: '' },
          sessions: [],
          weights: [],
          measurements: [],
          programs: [],
          foods: [],
          goals: { cal: 0, prot: 0, carb: 0, fat: 0 }
        };
        await _db.collection('users').doc(userId).set(newProfile);
        window._userData = newProfile;
      }
    } catch (err) {
      console.error("❌ Erreur chargement:", err);
    }
  };

  _auth.onAuthStateChanged((user) => {
    if (user) {
      window._currentUser = user;
      document.getElementById('auth-screen').style.display = 'none';
      document.getElementById('app').style.display = 'flex';
      document.getElementById('auth-user-badge').textContent = '👤 ' + user.email.split('@')[0];
      window._loadDBFromFirestore(user.uid);
    } else {
      window._currentUser = null;
      document.getElementById('auth-screen').style.display = 'flex';
      document.getElementById('app').style.display = 'none';
    }
  });
</script>