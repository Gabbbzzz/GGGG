let calMonth=new Date();
function prevMonth(){calMonth.setMonth(calMonth.getMonth()-1);renderCalendar();}
function nextMonth(){calMonth.setMonth(calMonth.getMonth()+1);renderCalendar();}

function renderCalendar(){
  const y=calMonth.getFullYear(),m=calMonth.getMonth();
  document.getElementById('cal-month-title').textContent=calMonth.toLocaleDateString('fr-FR',{month:'long',year:'numeric'});
  const first=new Date(y,m,1),last=new Date(y,m+1,0);
  let startDay=(first.getDay()+6)%7;
  const todayStr=today();
  let html='<div class="cal-h">L</div><div class="cal-h">M</div><div class="cal-h">M</div><div class="cal-h">J</div><div class="cal-h">V</div><div class="cal-h">S</div><div class="cal-h">D</div>';
  for(let i=0;i<startDay;i++)html+=`<div class="cal-d empty"></div>`;
  for(let d=1;d<=last.getDate();d++){
    const ds=`${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const hasSess=DB.sessions.some(s=>s.date===ds);
    const prog=DB.programs.find(p=>p.date===ds);
    let cls='cal-d';
    if(ds===todayStr)cls+=' today';
    else if(hasSess)cls+=' has-s';
    else if(prog&&prog.type==='Repos')cls+=' rest';
    html+=`<div class="${cls}" onclick="openAddProgram('${ds}')">${d}</div>`;
  }
  document.getElementById('calendar').innerHTML=html;
}

function renderWeekGrid(){
  const now=new Date();
  const mon=new Date(now);mon.setDate(now.getDate()-((now.getDay()+6)%7));
  const dayNames=['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'];
  let html='';
  for(let i=0;i<7;i++){
    const d=new Date(mon);d.setDate(mon.getDate()+i);
    const ds=d.toISOString().split('T')[0];
    const hasSess=DB.sessions.some(s=>s.date===ds);
    const prog=DB.programs.find(p=>p.date===ds);
    const isToday=d.toDateString()===now.toDateString();
    html+=`<div style="background:${hasSess?'rgba(200,241,53,.08)':isToday?'rgba(200,241,53,.04)':'var(--s2)'};border:1px solid ${isToday?'var(--acc)':hasSess?'rgba(200,241,53,.3)':'var(--bdr)'};border-radius:13px;padding:12px 8px;text-align:center;cursor:pointer" onclick="openAddProgram('${ds}')">
      <div style="font-size:10px;color:${isToday?'var(--acc)':'var(--txt3)'};font-weight:700;letter-spacing:.5px;text-transform:uppercase">${dayNames[i]}</div>
      <div style="font-size:20px;margin:6px 0">${hasSess?'✅':prog&&prog.type!=='Repos'?'📋':prog&&prog.type==='Repos'?'😴':'·'}</div>
      <div style="font-size:12px;color:${isToday?'var(--acc)':'var(--txt3)'};font-weight:600">${d.getDate()}</div>
      ${prog?`<div style="font-size:9px;color:var(--txt3);margin-top:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${prog.name}</div>`:''}
    </div>`;
  }
  document.getElementById('week-grid').innerHTML=html;
}

function openAddProgram(date=''){
  document.getElementById('prog-date').value=date||today();
  document.getElementById('prog-name').value='';
  openModal('program-modal');
}
function saveProgram(){
  const date=document.getElementById('prog-date').value;
  const name=document.getElementById('prog-name').value.trim();
  const type=document.getElementById('prog-type-val').value;
  if(!date||!name){notify('⚠️ Remplis tous les champs');return;}
  DB.programs.push({id:Date.now(),date,name,type});
  saveDB();closeModal('program-modal');renderCalendar();renderWeekGrid();
  notify('📅 Planifié !');
}

// ==================== TIMER ====================
let timerDuration=90,timerRemaining=90,timerRunning=false,timerInterval=null,timerTotal=90;
function setTimer(s){
  clearInterval(timerInterval);timerRunning=false;
  timerDuration=s;timerRemaining=s;timerTotal=s;
  updateTimerDisplay();
  document.getElementById('timer-start-btn').textContent='▶ Démarrer';
  const prog=document.getElementById('timer-progress');
  prog.style.width='100%';prog.style.background='var(--acc)';
}
function toggleTimer(){
  if(timerRunning){
    clearInterval(timerInterval);timerRunning=false;
    document.getElementById('timer-start-btn').textContent='▶ Reprendre';
  }else{
    timerRunning=true;
    document.getElementById('timer-start-btn').textContent='⏸ Pause';
    timerInterval=setInterval(()=>{
      timerRemaining--;
      if(timerRemaining<=0){
        timerRemaining=0;clearInterval(timerInterval);timerRunning=false;
        document.getElementById('timer-start-btn').textContent='▶ Démarrer';
        notify('⏰ Repos terminé ! En piste !');
        if(navigator.vibrate)navigator.vibrate([200,100,200]);
      }
      updateTimerDisplay();
      const pct=timerRemaining/timerTotal*100;
      const prog=document.getElementById('timer-progress');
      prog.style.width=pct+'%';
      prog.style.background=pct<20?'var(--acc2)':pct<50?'var(--acc4)':'var(--acc)';
    },1000);
  }
}
function resetTimer(){setTimer(timerDuration);}
function updateTimerDisplay(){
  const m=Math.floor(timerRemaining/60).toString().padStart(2,'0');
  const s=(timerRemaining%60).toString().padStart(2,'0');
  document.getElementById('rest-timer').textContent=`${m}:${s}`;
}

