<script>
// ==================== DB (Firebase) ====================
let DB={
  profile:{name:'Athlète',height:175,goal:'Prise de masse'},
  sessions:[],weights:[],measurements:[],programs:[],
  foods:[],goals:{cal:0,prot:0,carb:0,fat:0}
};

// Sauvegarde dans Firestore
async function saveDB(){
  if(!window._currentUser) return;
  try {
    await window._fbSetDoc('users', window._currentUser.uid, {data: JSON.stringify(DB)});
  } catch(e) {
    console.error('Erreur sauvegarde Firestore:', e);
    // Fallback localStorage
    localStorage.setItem('gymtrack_v3_backup', JSON.stringify(DB));
  }
}

// Chargement depuis Firestore
window._loadDBFromFirestore = async function(uid) {
  try {
    const snap = await window._fbGetDoc('users', uid);
    if(snap.exists && snap.data) {
      // Firestore retourne directement l'objet, pas besoin de parser
      DB = {...DB, ...snap.data};
      if(!DB.foods) DB.foods=[];
      if(!DB.goals) DB.goals={cal:0,prot:0,carb:0,fat:0};
      if(!DB.sessions) DB.sessions=[];
      if(!DB.weights) DB.weights=[];
      if(!DB.measurements) DB.measurements=[];
      if(!DB.programs) DB.programs=[];
    } else {
      // Nouvel utilisateur - initialiser la structure
      DB = {
        profile: { name: '', height: 0, goal: '' },
        sessions: [],
        weights: [],
        measurements: [],
        programs: [],
        foods: [],
        goals: { cal: 0, prot: 0, carb: 0, fat: 0 }
      };
    }
    // Init UI after loading
    document.getElementById('history-filter').value=new Date().toISOString().slice(0,7);
    document.getElementById('food-date-filter').value=today();
    loadGoals();
    renderDashboard();
    document.getElementById('username-display').textContent=DB.profile.name||'Athlète';
  } catch(e) {
    console.error('Erreur chargement Firestore:', e);
    notify('⚠️ Erreur chargement données');
  }
};

// Auth UI functions
function switchAuthTab(tab) {
  const isLogin = tab === 'login';
  document.getElementById('tab-login').classList.toggle('active', isLogin);
  document.getElementById('tab-signup').classList.toggle('active', !isLogin);
  document.getElementById('auth-name-wrap').style.display = isLogin ? 'none' : 'block';
  document.getElementById('auth-submit-btn').textContent = isLogin ? 'Se connecter' : 'Créer mon compte';
  document.getElementById('auth-error').classList.remove('show');
  document.querySelector('#auth-password').autocomplete = isLogin ? 'current-password' : 'new-password';
}

function showAuthError(msg) {
  const el = document.getElementById('auth-error');
  el.textContent = msg;
  el.classList.add('show');
  document.getElementById('auth-loading').classList.remove('show');
}

async function submitAuth() {
  const email = document.getElementById('auth-email').value.trim();
  const password = document.getElementById('auth-password').value;
  const isLogin = document.getElementById('tab-login').classList.contains('active');

  if(!email || !password) { showAuthError('⚠️ Remplis tous les champs'); return; }
  if(password.length < 6) { showAuthError('⚠️ Mot de passe trop court (6 caractères min)'); return; }

  // Check config (compat SDK)
  if(!window._fbAuth) {
    showAuthError('🔧 Firebase non chargé — réessaie dans un instant');
    return;
  }

  document.getElementById('auth-error').classList.remove('show');
  document.getElementById('auth-loading').classList.add('show');

  try {
    if(isLogin) {
      await window._fbSignIn(null, email, password);
    } else {
      const name = document.getElementById('auth-name').value.trim() || 'Athlète';
      const cred = await window._fbSignUp(null, email, password);
      // Initialise le profil avec le prénom
      DB.profile.name = name;
      window._currentUser = cred.user;
      await saveDB();
    }
  } catch(e) {
    const msgs = {
      'auth/user-not-found': '❌ Aucun compte avec cet email',
      'auth/wrong-password': '❌ Mot de passe incorrect',
      'auth/email-already-in-use': '❌ Email déjà utilisé',
      'auth/invalid-email': '❌ Email invalide',
      'auth/too-many-requests': '⏳ Trop de tentatives, réessaie dans un moment',
      'auth/invalid-credential': '❌ Email ou mot de passe incorrect',
    };
    showAuthError(msgs[e.code] || ('❌ Erreur : ' + e.message));
  }
}

function confirmLogout() {
  const email = window._currentUser?.email || '';
  if(confirm('Se déconnecter de ' + email + ' ?')) {
    window._fbSignOut().then(() => { DB = {profile:{name:'Athlète',height:175,goal:'Prise de masse'},sessions:[],weights:[],measurements:[],programs:[],foods:[],goals:{cal:0,prot:0,carb:0,fat:0}}; });
  }
}

// Allow Enter key on auth inputs
document.addEventListener('keydown', (e) => {
  if(e.key === 'Enter' && document.getElementById('auth-screen').style.display !== 'none') submitAuth();
});

// ==================== EXERCISES ====================
const EXERCISES=[
  {name:'Développé couché barre',muscle:'Pectoraux',machine:false,type:'Compound',icon:'🔴'},
