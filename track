            <div class="fg" style="margin:0"><label>Glucides (g)</label><input type="number" id="goal-carb" placeholder="300" oninput="saveGoals()" inputmode="numeric"></div>
            <div class="fg" style="margin:0"><label>Lipides (g)</label><input type="number" id="goal-fat" placeholder="70" oninput="saveGoals()" inputmode="numeric"></div>
          </div>
          <div style="margin-top:10px;font-size:13px;color:var(--txt3)">💡 <span class="hl" style="cursor:pointer" onclick="showPage('cmc')">Calculer automatiquement →</span></div>
        </div>
      </div>
    </div>

    <!-- ===== EXERCICES (library) ===== -->
    <div class="page" id="page-library">
      <div class="hero-section">
        <div class="hero-greeting" style="font-size:24px">📚 <span class="acc">Basic-Fit</span></div>
      </div>
      <div class="search-wrap" style="position:relative">
        <span class="search-ico" style="top:calc(50% - 6px)">🔍</span>
        <input type="text" class="search-input" id="lib-search" placeholder="Rechercher un exercice…" oninput="filterLibrarySearch()" style="padding-left:44px">
      </div>
      <div class="tabs" id="library-tabs">
        <button class="tab-btn active" onclick="filterLibrary('Tous')">Tous</button>
        <button class="tab-btn" onclick="filterLibrary('Pectoraux')">🫀 Pecs</button>
        <button class="tab-btn" onclick="filterLibrary('Dos')">🔙 Dos</button>
        <button class="tab-btn" onclick="filterLibrary('Épaules')">💪 Épaules</button>
        <button class="tab-btn" onclick="filterLibrary('Biceps')">💪 Biceps</button>
        <button class="tab-btn" onclick="filterLibrary('Triceps')">💪 Triceps</button>
        <button class="tab-btn" onclick="filterLibrary('Jambes')">🦵 Jambes</button>
        <button class="tab-btn" onclick="filterLibrary('Abdominaux')">⚡ Abdos</button>
        <button class="tab-btn" onclick="filterLibrary('Cardio')">❤️ Cardio</button>
      </div>
      <div class="exo-grid" id="library-grid" style="padding:0 16px 16px"></div>
    </div>

    <!-- ===== MORE PAGES ===== -->

    <!-- HISTORIQUE -->
    <div class="page" id="page-history">
      <div class="hero-section">
        <div style="display:flex;align-items:center;justify-content:space-between">
          <div class="hero-greeting" style="font-size:24px">📋 <span class="acc">Historique</span></div>
          <input type="month" id="history-filter" onchange="renderHistory()" style="width:auto;padding:9px 14px;font-size:13px;border-radius:13px">
        </div>
